<style>
  :root {
    --navy: #0f1b35;
    --navy-mid: #1e3157;
    --accent: #2563a8;
    --accent-light: #3b82c4;
    --gold: #c8922a;
    --gold-light: #e5b84a;
    --surface: #f7f8fb;
    --surface2: #eef0f6;
    --border: #dde1ec;
    --text: #1a2035;
    --text-mid: #4a5370;
    --text-muted: #7a829a;
    --white: #ffffff;
    --radius: 12px;
    --radius-sm: 8px;
    --nav-h: 64px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    color: var(--text);
    background: var(--white);
    line-height: 1.7;
    font-size: 16px;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    height: var(--nav-h);
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 2rem;
  }

  .nav-logo {
    font-family: 'DM Serif Display', serif;
    font-size: 1.2rem; color: var(--navy); text-decoration: none;
    letter-spacing: -0.3px;
  }

  .nav-links { display: flex; gap: 0.25rem; }

  .nav-links a {
    font-size: 0.85rem; font-weight: 400; color: var(--text-mid);
    text-decoration: none; padding: 6px 12px; border-radius: 6px;
    transition: all 0.2s;
  }

  .nav-links a:hover, .nav-links a.active {
    color: var(--accent); background: #e8f0fa;
  }

  /* ── LAYOUT ── */
  main { padding-top: var(--nav-h); }

  section {
    padding: 5rem 0;
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  section.visible { opacity: 1; transform: translateY(0); }

  .container { max-width: 960px; margin: 0 auto; padding: 0 2rem; }

  /* ── SECTION HEADERS ── */
  .section-label {
    font-size: 0.75rem; font-weight: 500; letter-spacing: 2px;
    text-transform: uppercase; color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: 2rem; color: var(--navy);
    line-height: 1.2; margin-bottom: 2.5rem;
  }

  /* ── HERO ── */
  #home {
    min-height: calc(100vh - var(--nav-h));
    background: linear-gradient(160deg, var(--navy) 0%, var(--navy-mid) 60%, #1a3a6e 100%);
    display: flex; align-items: center;
    padding: 3rem 0; opacity: 1; transform: none;
  }

  .hero-inner {
    max-width: 960px; margin: 0 auto; padding: 0 2rem;
    display: grid; grid-template-columns: 1fr 280px; gap: 4rem; align-items: center;
  }

  .hero-tag {
    display: inline-block;
    font-size: 0.72rem; font-weight: 500; letter-spacing: 2px;
    text-transform: uppercase; color: var(--gold-light);
    background: rgba(200,146,42,0.15);
    border: 1px solid rgba(200,146,42,0.3);
    padding: 5px 14px; border-radius: 20px; margin-bottom: 1.5rem;
  }

  .hero-name {
    font-family: 'DM Serif Display', serif;
    font-size: 3rem; color: var(--white);
    line-height: 1.15; margin-bottom: 1rem;
    letter-spacing: -0.5px;
  }

  .hero-title {
    font-size: 1.05rem; color: rgba(255,255,255,0.75);
    font-weight: 300; margin-bottom: 0.5rem;
  }

  .hero-affil {
    font-size: 0.9rem; color: rgba(255,255,255,0.5);
    margin-bottom: 2rem;
  }

  .hero-bio {
    font-size: 0.95rem; color: rgba(255,255,255,0.7);
    line-height: 1.8; max-width: 560px; margin-bottom: 2rem;
  }

  .hero-links { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2rem; }

  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.85rem; font-weight: 500;
    padding: 10px 20px; border-radius: var(--radius-sm);
    text-decoration: none; transition: all 0.2s; cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--gold); color: var(--navy);
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-1px); }

  .btn-outline {
    background: transparent; color: var(--white);
    border: 1px solid rgba(255,255,255,0.3);
  }
  .btn-outline:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.6); }

  .btn-sm {
    font-size: 0.8rem; padding: 7px 14px;
    background: var(--surface); color: var(--text-mid);
    border: 1px solid var(--border);
  }
  .btn-sm:hover { border-color: var(--accent); color: var(--accent); }

  .social-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  .social-btn {
    font-size: 0.78rem; color: rgba(255,255,255,0.55);
    text-decoration: none; padding: 5px 12px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 20px; transition: all 0.2s;
  }
  .social-btn:hover { color: var(--white); border-color: rgba(255,255,255,0.4); }

  .hero-photo-wrap {
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
  }

  .hero-photo {
    width: 220px; height: 220px; border-radius: 50%;
    object-fit: cover;
    border: 4px solid rgba(255,255,255,0.15);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }

  .hero-badges { display: flex; flex-wrap: wrap; gap: 6px; justify-content: center; }

  .badge {
    font-size: 0.72rem; padding: 4px 10px; border-radius: 20px;
    font-weight: 400;
  }
  .badge-blue { background: rgba(59,130,196,0.2); color: #7ec3f5; border: 1px solid rgba(59,130,196,0.3); }
  .badge-gold { background: rgba(200,146,42,0.2); color: var(--gold-light); border: 1px solid rgba(200,146,42,0.3); }

  /* ── RESEARCH ── */
  #research { background: var(--surface); }

  .research-areas {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .area-card {
    background: var(--white); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.5rem;
    transition: all 0.25s;
    position: relative; overflow: hidden;
  }

  .area-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--gold));
  }

  .area-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(15,27,53,0.1); }

  .area-icon {
    width: 40px; height: 40px; border-radius: 10px;
    background: #e8f0fa; display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; margin-bottom: 1rem;
  }

  .area-title { font-size: 0.95rem; font-weight: 500; color: var(--navy); margin-bottom: 0.4rem; }
  .area-desc { font-size: 0.83rem; color: var(--text-mid); line-height: 1.6; }

  .current-project {
    background: var(--white); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 2rem;
    border-left: 4px solid var(--accent);
  }

  .project-label { font-size: 0.72rem; font-weight: 500; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--accent); margin-bottom: 0.5rem; }
  .project-title { font-size: 1.1rem; font-weight: 500; color: var(--navy); margin-bottom: 0.5rem; }
  .project-desc { font-size: 0.9rem; color: var(--text-mid); }

  /* ── PUBLICATIONS ── */
  #publications { background: var(--white); }

  .pub-list { display: flex; flex-direction: column; gap: 1rem; }

  .pub-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.5rem;
    transition: all 0.2s;
  }

  .pub-card:hover { border-color: var(--accent-light); }

  .pub-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 0.5rem; flex-wrap: wrap; }

  .pub-type {
    font-size: 0.7rem; font-weight: 500; letter-spacing: 1px;
    text-transform: uppercase; padding: 3px 9px; border-radius: 20px;
  }
  .pub-journal { background: #e8f0fa; color: var(--accent); }
  .pub-conf { background: #fef3e2; color: #a06c10; }
  .pub-year { font-size: 0.8rem; color: var(--text-muted); }

  .pub-title { font-size: 0.97rem; font-weight: 500; color: var(--navy); margin-bottom: 0.35rem; line-height: 1.45; }
  .pub-authors { font-size: 0.83rem; color: var(--text-mid); margin-bottom: 0.35rem; }
  .pub-venue { font-size: 0.83rem; color: var(--text-muted); font-style: italic; margin-bottom: 0.75rem; }
  .pub-links { display: flex; gap: 0.5rem; flex-wrap: wrap; }

  /* ── TEACHING ── */
  #teaching { background: var(--surface); }

  .teach-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }

  .teach-card {
    background: var(--white); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.5rem;
    transition: all 0.2s;
  }
  .teach-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(15,27,53,0.08); }

  .teach-role { font-size: 0.72rem; font-weight: 500; letter-spacing: 1px;
    text-transform: uppercase; color: var(--gold); margin-bottom: 0.4rem; }
  .teach-course { font-size: 0.97rem; font-weight: 500; color: var(--navy); margin-bottom: 0.2rem; }
  .teach-where { font-size: 0.83rem; color: var(--text-mid); margin-bottom: 0.5rem; }
  .teach-term { font-size: 0.78rem; color: var(--text-muted); }

  /* ── ACTIVITIES ── */
  #activities { background: var(--white); }

  .activity-list { display: flex; flex-direction: column; gap: 0; }

  .activity-item {
    display: grid; grid-template-columns: 90px 1fr;
    gap: 1.5rem; padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
    transition: all 0.2s;
  }
  .activity-item:last-child { border-bottom: none; }
  .activity-item:hover { padding-left: 6px; }

  .activity-year {
    font-size: 0.8rem; color: var(--text-muted);
    padding-top: 2px; font-weight: 500;
  }

  .activity-role { font-size: 0.72rem; font-weight: 500; letter-spacing: 1px;
    text-transform: uppercase; color: var(--accent); margin-bottom: 0.3rem; }
  .activity-title { font-size: 0.95rem; font-weight: 500; color: var(--text); margin-bottom: 0.2rem; }
  .activity-org { font-size: 0.85rem; color: var(--text-mid); }

  /* ── BLOG ── */
  #blog { background: var(--surface); }

  .blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }

  .blog-card {
    background: var(--white); border: 1px solid var(--border);
    border-radius: var(--radius); overflow: hidden;
    text-decoration: none; display: block;
    transition: all 0.25s;
  }
  .blog-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(15,27,53,0.1); }

  .blog-thumb {
    height: 120px;
    display: flex; align-items: center; justify-content: center;
    font-size: 2.5rem;
  }
  .blog-thumb-1 { background: linear-gradient(135deg, #1e3157, #2563a8); }
  .blog-thumb-2 { background: linear-gradient(135deg, #1a3a2a, #2e7a50); }
  .blog-thumb-3 { background: linear-gradient(135deg, #3a1a35, #7a3a70); }

  .blog-body { padding: 1.25rem; }
  .blog-tag { font-size: 0.7rem; font-weight: 500; letter-spacing: 1px;
    text-transform: uppercase; color: var(--accent); margin-bottom: 0.4rem; }
  .blog-title { font-size: 0.92rem; font-weight: 500; color: var(--navy);
    line-height: 1.45; margin-bottom: 0.5rem; }
  .blog-date { font-size: 0.78rem; color: var(--text-muted); }

  /* ── CV ── */
  #cv { background: var(--white); }

  .cv-inner {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 3rem; text-align: center;
  }

  .cv-icon { font-size: 3rem; margin-bottom: 1rem; }
  .cv-title { font-family: 'DM Serif Display', serif; font-size: 1.5rem;
    color: var(--navy); margin-bottom: 0.5rem; }
  .cv-sub { font-size: 0.9rem; color: var(--text-mid); margin-bottom: 2rem; }
  .cv-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  .btn-cv-primary {
    background: var(--navy); color: var(--white);
    padding: 12px 28px; border-radius: var(--radius-sm);
    text-decoration: none; font-size: 0.9rem; font-weight: 500;
    display: inline-flex; align-items: center; gap: 8px;
    transition: all 0.2s;
  }
  .btn-cv-primary:hover { background: var(--navy-mid); transform: translateY(-1px); }

  .btn-cv-outline {
    background: transparent; color: var(--navy);
    padding: 12px 28px; border-radius: var(--radius-sm);
    border: 1px solid var(--border); text-decoration: none;
    font-size: 0.9rem; font-weight: 500;
    display: inline-flex; align-items: center; gap: 8px;
    transition: all 0.2s;
  }
  .btn-cv-outline:hover { border-color: var(--accent); color: var(--accent); }

  /* ── FOOTER ── */
  footer {
    background: var(--navy); color: rgba(255,255,255,0.5);
    padding: 2rem; text-align: center; font-size: 0.82rem;
  }

  footer a { color: rgba(255,255,255,0.7); text-decoration: none; }
  footer a:hover { color: var(--white); }

  /* ── DIVIDER ── */
  .divider { height: 1px; background: var(--border); }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; text-align: center; }
    .hero-photo-wrap { order: -1; }
    .hero-links, .social-row { justify-content: center; }
    .research-areas, .teach-grid, .blog-grid { grid-template-columns: 1fr; }
    .nav-links { display: none; }
    .hero-name { font-size: 2rem; }
    .hero-bio { margin: 0 auto 2rem; }
  }
</style>
</head>
